generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_URL_DIRECT")
}

enum Role {
  STUDENT
  WARDEN
  ADMIN
  COUNSELLOR
  DOCTOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum ComplaintStatus {
  PENDING
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANING
  FURNITURE
  SECURITY
  FOOD
  INTERNET
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CleaningAssignmentStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum SessionStatus {
  OPEN
  ACTIVE
  CLOSED
  ARCHIVED
}

enum Mood {
  ANXIOUS
  SAD
  STRESSED
  OKAY
  GOOD
}

enum MessageType {
  TEXT
  RESOURCE
  NOTE
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LeaveType {
  HOME
  MEDICAL
  PERSONAL
  EMERGENCY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED_BY_WARDEN
  APPROVED
  REJECTED
  CANCELLED
}

enum HealthAppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PrescriptionStatus {
  ISSUED
  DISPENSED
  CANCELLED
}

enum InsuranceClaimStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum MedicalDocumentStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  role            Role           @default(STUDENT)
  phone           String?
  avatarUrl       String?
  enrollmentNo    String?        @unique
  course          String?
  coursePreference String?
  gender          Gender?
  sportsInterests String[]       @default([])
  hobbies         String[]       @default([])
  sleepSchedule   String?
  noiseTolerance  String?
  studyHours      Int?
  sleepHours      Int?
  careerGoal      String?
  address         String?
  parentContactNo String?
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  allocation      RoomAllocation?
  complaints      Complaint[]
  maintenanceTasks MaintenanceTask[] @relation("MaintenanceCreatedBy")
  notifications   Notification[]
  cleaningFeedback CleaningFeedback[]
  counsellorProfile CounsellorProfile?
  doctorProfile DoctorProfile?
  studentSessions CounsellingSession[] @relation("StudentSessions")
  sentMessages CounsellingMessage[] @relation("SentMessages")
  journalEntries JournalEntry[]
  createdAppointments CounsellingAppointment[] @relation("AppointmentCreatedBy")
  healthAppointments HealthAppointment[] @relation("HealthAppointmentStudent")
  insuranceClaims InsuranceClaim[] @relation("InsuranceClaimStudent")
  processedClaims InsuranceClaim[] @relation("InsuranceClaimProcessedBy")
  medicalLeaveRequests MedicalLeaveRequest[] @relation("MedicalLeaveStudent")
  verifiedMedicalLeaveRequests MedicalLeaveRequest[] @relation("MedicalLeaveVerifiedBy")
  leaves Leave[]
  @@map("users")
}

model Room {
  id          String           @id @default(uuid())
  number      String           @unique
  floor       Int
  block       String
  capacity    Int              @default(2)
  status      RoomStatus       @default(AVAILABLE)
  amenities   String[]
  createdAt   DateTime         @default(now())
  allocations RoomAllocation[]
  cleaningAssignments CleaningAssignment[]

  @@map("rooms")
}

model RoomAllocation {
  id          String    @id @default(uuid())
  userId      String    @unique
  roomId      String
  allocatedAt DateTime  @default(now())
  vacatedAt   DateTime?
  isActive    Boolean   @default(true)
  user        User      @relation(fields: [userId], references: [id])
  room        Room      @relation(fields: [roomId], references: [id])

  @@map("room_allocations")
}

model Complaint {
  id          String             @id @default(uuid())
  token       String             @unique @default(cuid())
  isAnonymous Boolean            @default(false)
  userId      String?
  roomNumber  String?
  category    ComplaintCategory
  title       String
  description String
  imageUrl    String?
  status      ComplaintStatus    @default(PENDING)
  adminNote   String?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User?              @relation(fields: [userId], references: [id])
  identity    ComplaintIdentity?

  @@map("complaints")
}

model ComplaintIdentity {
  id          String    @id @default(uuid())
  complaintId String    @unique
  studentHash String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@map("complaint_identities")
}

model MaintenanceTask {
  id          String            @id @default(uuid())
  title       String
  description String
  location    String
  assignedTo  String?
  status      MaintenanceStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  createdByUserId String?
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())

  createdByUser User? @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id])

  @@map("maintenance_tasks")
}

model Announcement {
  id        String    @id @default(uuid())
  title     String
  content   String
  isUrgent  Boolean   @default(false)
  createdBy String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("announcements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model CleaningStaff {
  id        String              @id @default(uuid())
  name      String
  phone     String?
  zone      String?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  assignments CleaningAssignment[]

  @@map("cleaning_staff")
}

model CleaningAssignment {
  id             String                  @id @default(uuid())
  roomId         String
  staffId        String
  scheduledStart DateTime
  scheduledEnd   DateTime
  status         CleaningAssignmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  room    Room         @relation(fields: [roomId], references: [id])
  staff   CleaningStaff @relation(fields: [staffId], references: [id])
  feedback CleaningFeedback?

  @@index([scheduledStart])
  @@index([roomId, scheduledStart])
  @@map("cleaning_assignments")
}

model CleaningFeedback {
  id           String   @id @default(uuid())
  assignmentId String   @unique
  userId       String
  cleaned      Boolean  @default(true)
  rating       Int
  comment      String?
  submittedAt  DateTime @default(now())

  assignment CleaningAssignment @relation(fields: [assignmentId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@index([userId, submittedAt])
  @@map("cleaning_feedback")
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  content   String
  embedding String?
  metadata  Json
  createdAt DateTime @default(now())

  @@map("knowledge_base")
}

model CounsellorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  specialties   String[]
  availability  String?
  isOnline      Boolean  @default(false)
  sessions      CounsellingSession[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("counsellor_profiles")
}

model CounsellingSession {
  id             String    @id @default(cuid())
  studentId      String
  counsellorId   String
  student        User      @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)
  counsellor     CounsellorProfile @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
  status         SessionStatus @default(OPEN)
  topic          String?
  mood           Mood?
  startedAt      DateTime  @default(now())
  closedAt       DateTime?
  messages       CounsellingMessage[]
  appointments   CounsellingAppointment[]
  journalEntries JournalEntry[]
  sessionNotes   String?
  followUpDate   DateTime?
  rating         Int?
  ratingComment  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([studentId])
  @@index([counsellorId])
  @@index([status])
  @@map("counselling_sessions")
}

model CounsellingAppointment {
  id           String            @id @default(cuid())
  sessionId    String
  session      CounsellingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  durationMins Int               @default(30)
  status       AppointmentStatus @default(REQUESTED)
  note         String?
  meetingLink  String?
  createdById  String
  createdBy    User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([sessionId])
  @@index([scheduledAt])
  @@index([status])
  @@map("counselling_appointments")
}

model CounsellingMessage {
  id          String   @id @default(cuid())
  sessionId   String
  session     CounsellingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  type        MessageType @default(TEXT)
  isRead      Boolean  @default(false)
  readAt      DateTime?
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([senderId])
  @@index([isRead])
  @@map("counselling_messages")
}

model JournalEntry {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId String?
  session   CounsellingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mood      Mood?
  title     String?
  content   String
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, createdAt])
  @@index([isShared])
  @@map("journal_entries")
}

model DoctorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String?
  clinicLocation String?
  availabilityNote String?
  isActive      Boolean  @default(true)
  availability  DoctorAvailability[]
  appointments  HealthAppointment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("doctor_profiles")
}

model DoctorAvailability {
  id             String   @id @default(cuid())
  doctorId       String
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startMinute    Int
  endMinute      Int
  slotDurationMins Int @default(30)
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([doctorId, dayOfWeek])
  @@map("doctor_availability")
}

model HealthAppointment {
  id          String  @id @default(cuid())
  studentId   String
  student     User    @relation("HealthAppointmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  doctorId    String
  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status      HealthAppointmentStatus @default(REQUESTED)
  scheduledAt DateTime
  durationMins Int @default(30)
  reason      String?
  adminNote   String?
  record      HealthVisitRecord?
  claims      InsuranceClaim[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([status])
  @@map("health_appointments")
}

model HealthVisitRecord {
  id            String  @id @default(cuid())
  appointmentId String  @unique
  appointment   HealthAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  symptoms      String?
  diagnosis     String?
  treatmentPlan String?
  doctorNotes   String?
  attachments   String[] @default([])
  prescription  Prescription?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("health_visit_records")
}

model Prescription {
  id        String @id @default(cuid())
  recordId  String @unique
  record    HealthVisitRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  status    PrescriptionStatus @default(ISSUED)
  notes     String?
  items     PrescriptionItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String?
  medicine       Medicine? @relation(fields: [medicineId], references: [id], onDelete: SetNull)
  medicineName   String
  dosage         String?
  frequency      String?
  durationDays   Int?
  instructions   String?
  quantity       Int?

  @@index([prescriptionId])
  @@index([medicineId])
  @@map("prescription_items")
}

model Medicine {
  id               String @id @default(cuid())
  name             String @unique
  description      String?
  unit             String?
  stockQty         Int @default(0)
  lowStockThreshold Int @default(10)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  prescriptionItems PrescriptionItem[]

  @@index([stockQty])
  @@map("medicines")
}

model InsuranceClaim {
  id            String @id @default(cuid())
  studentId     String
  student       User   @relation("InsuranceClaimStudent", fields: [studentId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   HealthAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  amount        Int?
  description   String?
  billUrl       String?
  status        InsuranceClaimStatus @default(SUBMITTED)
  adminNote     String?
  processedById String?
  processedBy   User? @relation("InsuranceClaimProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([studentId, createdAt])
  @@index([status])
  @@map("insurance_claims")
}

model MedicalLeaveRequest {
  id          String @id @default(cuid())
  studentId   String
  student     User   @relation("MedicalLeaveStudent", fields: [studentId], references: [id], onDelete: Cascade)
  fromDate    DateTime
  toDate      DateTime
  reason      String
  documentUrl String?
  status      MedicalDocumentStatus @default(SUBMITTED)
  adminNote   String?
  verifiedById String?
  verifiedBy  User?  @relation("MedicalLeaveVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId, createdAt])
  @@index([status])
  @@map("medical_leave_requests")
}

model Leave {
  id            String      @id @default(cuid())
  studentId     String
  student       User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reason        String
  leaveType     LeaveType
  fromDate      DateTime
  toDate        DateTime
  destination   String
  contactNumber String
  parentContact String
  status        LeaveStatus @default(PENDING)
  wardenRemark  String?
  adminRemark   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([fromDate])
  @@map("leaves")
}
