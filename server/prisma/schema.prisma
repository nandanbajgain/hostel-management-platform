generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_URL_DIRECT")
}

enum Role {
  STUDENT
  WARDEN
  ADMIN
  COUNSELLOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum ComplaintStatus {
  PENDING
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ComplaintCategory {
  PLUMBING
  ELECTRICAL
  CLEANING
  FURNITURE
  SECURITY
  FOOD
  INTERNET
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CleaningAssignmentStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum SessionStatus {
  OPEN
  ACTIVE
  CLOSED
  ARCHIVED
}

enum Mood {
  ANXIOUS
  SAD
  STRESSED
  OKAY
  GOOD
}

enum MessageType {
  TEXT
  RESOURCE
  NOTE
}

enum LeaveType {
  HOME
  MEDICAL
  PERSONAL
  EMERGENCY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED_BY_WARDEN
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  role            Role           @default(STUDENT)
  phone           String?
  avatarUrl       String?
  enrollmentNo    String?        @unique
  course          String?
  gender          Gender?
  sportsInterests String[]
  careerGoal      String?
  address         String?
  parentContactNo String?
  approvalStatus  ApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  allocation      RoomAllocation?
  complaints      Complaint[]
  maintenanceTasks MaintenanceTask[] @relation("MaintenanceCreatedBy")
  notifications   Notification[]
  cleaningFeedback CleaningFeedback[]
  counsellorProfile CounsellorProfile?
  studentSessions CounsellingSession[] @relation("StudentSessions")
  sentMessages CounsellingMessage[] @relation("SentMessages")
  leaves Leave[]
  @@map("users")
}

model Room {
  id          String           @id @default(uuid())
  number      String           @unique
  floor       Int
  block       String
  capacity    Int              @default(2)
  status      RoomStatus       @default(AVAILABLE)
  amenities   String[]
  createdAt   DateTime         @default(now())
  allocations RoomAllocation[]
  cleaningAssignments CleaningAssignment[]

  @@map("rooms")
}

model RoomAllocation {
  id          String    @id @default(uuid())
  userId      String    @unique
  roomId      String
  allocatedAt DateTime  @default(now())
  vacatedAt   DateTime?
  isActive    Boolean   @default(true)
  user        User      @relation(fields: [userId], references: [id])
  room        Room      @relation(fields: [roomId], references: [id])

  @@map("room_allocations")
}

model Complaint {
  id          String             @id @default(uuid())
  token       String             @unique @default(cuid())
  isAnonymous Boolean            @default(false)
  userId      String?
  roomNumber  String?
  category    ComplaintCategory
  title       String
  description String
  imageUrl    String?
  status      ComplaintStatus    @default(PENDING)
  adminNote   String?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User?              @relation(fields: [userId], references: [id])
  identity    ComplaintIdentity?

  @@map("complaints")
}

model ComplaintIdentity {
  id          String    @id @default(uuid())
  complaintId String    @unique
  studentHash String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@map("complaint_identities")
}

model MaintenanceTask {
  id          String            @id @default(uuid())
  title       String
  description String
  location    String
  assignedTo  String?
  status      MaintenanceStatus @default(SCHEDULED)
  scheduledAt DateTime
  completedAt DateTime?
  createdByUserId String?
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())

  createdByUser User? @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id])

  @@map("maintenance_tasks")
}

model Announcement {
  id        String    @id @default(uuid())
  title     String
  content   String
  isUrgent  Boolean   @default(false)
  createdBy String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("announcements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("info")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model CleaningStaff {
  id        String              @id @default(uuid())
  name      String
  phone     String?
  zone      String?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  assignments CleaningAssignment[]

  @@map("cleaning_staff")
}

model CleaningAssignment {
  id             String                  @id @default(uuid())
  roomId         String
  staffId        String
  scheduledStart DateTime
  scheduledEnd   DateTime
  status         CleaningAssignmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  room    Room         @relation(fields: [roomId], references: [id])
  staff   CleaningStaff @relation(fields: [staffId], references: [id])
  feedback CleaningFeedback?

  @@index([scheduledStart])
  @@index([roomId, scheduledStart])
  @@map("cleaning_assignments")
}

model CleaningFeedback {
  id           String   @id @default(uuid())
  assignmentId String   @unique
  userId       String
  cleaned      Boolean  @default(true)
  rating       Int
  comment      String?
  submittedAt  DateTime @default(now())

  assignment CleaningAssignment @relation(fields: [assignmentId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@index([userId, submittedAt])
  @@map("cleaning_feedback")
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  content   String
  embedding String?
  metadata  Json
  createdAt DateTime @default(now())

  @@map("knowledge_base")
}

model CounsellorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  specialties   String[]
  availability  String?
  isOnline      Boolean  @default(false)
  sessions      CounsellingSession[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("counsellor_profiles")
}

model CounsellingSession {
  id             String    @id @default(cuid())
  studentId      String
  counsellorId   String
  student        User      @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)
  counsellor     CounsellorProfile @relation(fields: [counsellorId], references: [id], onDelete: Cascade)
  status         SessionStatus @default(OPEN)
  topic          String?
  mood           Mood?
  startedAt      DateTime  @default(now())
  closedAt       DateTime?
  messages       CounsellingMessage[]
  sessionNotes   String?
  followUpDate   DateTime?
  rating         Int?
  ratingComment  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([studentId])
  @@index([counsellorId])
  @@index([status])
  @@map("counselling_sessions")
}

model CounsellingMessage {
  id          String   @id @default(cuid())
  sessionId   String
  session     CounsellingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  type        MessageType @default(TEXT)
  isRead      Boolean  @default(false)
  readAt      DateTime?
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([senderId])
  @@index([isRead])
  @@map("counselling_messages")
}

model Leave {
  id            String      @id @default(cuid())
  studentId     String
  student       User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reason        String
  leaveType     LeaveType
  fromDate      DateTime
  toDate        DateTime
  destination   String
  contactNumber String
  parentContact String
  status        LeaveStatus @default(PENDING)
  wardenRemark  String?
  adminRemark   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([fromDate])
  @@map("leaves")
}
