DATABASE_URL="postgresql://USER:PASSWORD@ep-example-region.aws.neon.tech/hostel_platform?sslmode=require"
REDIS_URL="rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST:6379"
JWT_SECRET="hostel-jwt-secret-change-in-prod-2026"
JWT_REFRESH_SECRET="hostel-refresh-secret-change-in-prod-2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Chatbot (Gemini + RAG)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_CHAT_MODEL="gemini-1.5-flash"
# Optional: set to a model that supports embedContent for your key (otherwise the server will auto-detect via ListModels)
GEMINI_EMBED_MODEL=""
GEMINI_API_BASE_URL="https://generativelanguage.googleapis.com"

# Optional (used for anonymous complaint image validation)
ANTHROPIC_API_KEY="sk-ant-your-key-here"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
HASH_SALT="sau-hostel-anon-salt-2026"
HOSTEL_NAME="South Asian University Hostel"
PORT=3001
HOST=0.0.0.0
SERVER_PUBLIC_URL="https://api.yourdomain.com"
CLIENT_URL="http://localhost:5173,https://app.yourdomain.com,https://your-vercel-project.vercel.app"
NODE_ENV="production"
